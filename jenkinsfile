pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/Aniket6300/Jenkins-Terraform-Automation-Project.git'
            }
        }

        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }

        stage('Terraform Plan') {
            steps {
                sh 'terraform plan'
            }
        }

        stage('Terraform Apply') {
            steps {
                sh 'terraform apply -auto-approve'
            }
        }
    }
}